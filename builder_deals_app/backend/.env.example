# Copy to .env and fill in keys to enable real data sources.
# Leave blank to use the bundled mock dataset.

LEAD_SOURCE=mock            # mock | rapidapi_zillow | rentcast
RAPIDAPI_KEY=
RAPIDAPI_ZILLOW_HOST=zillow-com1.p.rapidapi.com
RENTCAST_API_KEY=

# Default underwriting assumptions
DEFAULT_LOAN_LTV=0.70
DEFAULT_LOAN_RATE=0.085
DEFAULT_CLOSING_PCT=0.02
DEFAULT_SALE_COMMISSION_PCT=0.055
