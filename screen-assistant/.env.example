# Copy this file to ".env" and fill in your key.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model used for vision + reasoning. Sonnet 5 is a good default (fast, strong vision).
# Swap to claude-opus-4-8 for the hardest planning tasks.
ANTHROPIC_MODEL=claude-sonnet-5

# --- Autonomous execution (computer-use) ---
# Model that drives the mouse/keyboard loop. Must support computer-use.
# Leave blank to reuse ANTHROPIC_MODEL.
# SA_COMPUTER_USE_MODEL=claude-sonnet-5
# SA_COMPUTER_TOOL_TYPE=computer_20251124
# SA_COMPUTER_BETA=computer-use-2025-11-24

# Safety / tuning
SA_MAX_STEPS=40
SA_ACTION_DELAY_MS=350
SA_TARGET_WIDTH=1280
# Require confirmation before EVERY action (paranoid mode): set to 1
# SA_CONFIRM_EVERY=1
# Full Control — act without asking for approval (STOP kill switch still works): set to 1
# SA_FULL_CONTROL=1

# --- Phase 2: continuous private capture (in-memory, local only) ---
SA_WATCH_INTERVAL_MS=3000
SA_WATCH_MAX_FRAMES=40
