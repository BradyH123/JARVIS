# Copy this file to .env and fill in the providers you want to enable.
# A provider with missing credentials is simply shown as "not configured".
# NEVER commit your real .env — it is git-ignored.

# --- App ---
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
SECRET_KEY=change-this-to-a-long-random-string

# Session cookie policy. Defaults below are correct for local dev. If you deploy
# the frontend and backend on different domains, set these to None / true.
# See DEPLOY.md.
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false

# --- Spotify ---  (free)  https://developer.spotify.com/dashboard
# Create an app, then add this exact Redirect URI in its settings:
#   http://localhost:5000/api/auth/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:5000/api/auth/spotify/callback

# --- Apple Music ---  (paid Apple Developer account, $99/yr)
# https://developer.apple.com/  -> Certificates, Identifiers & Profiles -> Keys
# Create a MusicKit key; you get a Key ID and a .p8 file. Team ID is in Membership.
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Either paste the .p8 contents (newlines as \n) OR give a path to the file:
APPLE_PRIVATE_KEY=
APPLE_PRIVATE_KEY_PATH=

# --- SoundCloud ---  (NOTE: new app registration is currently closed by SoundCloud)
# https://developers.soundcloud.com/
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_REDIRECT_URI=http://localhost:5000/api/auth/soundcloud/callback
